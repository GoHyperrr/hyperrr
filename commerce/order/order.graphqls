extend type Query {
  getOrder(id: ID!): Order
  listOrders: [Order!]!
  listCustomerOrders(customerId: ID!): [Order!]!
}

extend type Mutation {
  createOrderFromCart(cartId: ID!): Order!
}

type Order {
  id: ID!
  customerId: String!
  status: String!
  totalPrice: Float!
  items: [OrderItem!]!
}

type OrderItem {
  id: ID!
  productId: String!
  quantity: Int!
  unitPrice: Float!
}
